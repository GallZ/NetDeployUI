{
  "name": "netdeploy-ui",
  "version": "1.0.0",
  "homepage": ".",
  "description": "Network Configuration Suite",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "electron-builder"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  },
  "build": {
    "appId": "com.snlink.netdeployui",
    "productName": "NetDeployUI",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-react/**/*",
      "electron.js",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
